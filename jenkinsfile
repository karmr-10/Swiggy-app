pipeline {
    agent any

    tools {
        jdk 'jdk17'
        nodejs 'node20' // Node.js 20 LTS
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }

    stages {


        stage('Checkout from Git') {
            steps {
                git branch: 'master', url: 'https://github.com/karmr-10/Swiggy-app.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh "npm install"
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar') {
                    sh """
                        $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectKey=Panigrahan-karthik \
                        -Dsonar.projectName=Panigrahan-karthik \
                        -Dsonar.sources=.
                    """

                    
                }
            }
        }

        stage('Quality Gate') {
            steps {
                script {
                    timeout(time: 5, unit: 'MINUTES') {
                        waitForQualityGate abortPipeline: true
                    }
                }
            }
        }

        
    }

    post {
        always {
            echo "Pipeline execution completed!"
        }
        failure {
            echo "Pipeline failed. Check logs for details."
        }
        success {
            echo "Swiggy App deployed successfully!"
        }
    }
}
