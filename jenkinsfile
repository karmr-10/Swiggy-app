pipeline {
    agent any

    tools {
        jdk 'jdk21'
        nodejs 'node20'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }

    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout from Git') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/karmr-10/Swiggy-app.git'
            }
        }
        
        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar') {
                    sh '''
                        $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectKey=Panigrahan-karthik \
                        -Dsonar.projectName=Panigrahan-karthik \
                        -Dsonar.sources=.
                    '''
                }
            }
        }

        stage('Docker Build and push') {
            steps {
                withDockerRegistry(credentialsId:'docker-credentials', url:'') {
                    sh '''
                        docker build -t swiggy:v1.0.1 .
                        docker tag swiggy:v1.0.1 dockkart2025/swiggy:v1.0.1
                        docker push dockkart2025/swiggy:v1.0.1
                    '''
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline execution completed!'
        }
        success {
            echo 'Panigrahan Web App pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed. Check Console Output.'
        }
    }
}